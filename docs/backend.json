
{
  "entities": {
    "Startup": {
      "title": "Startup",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "description": { "type": "string" },
        "status": { "type": "string", "enum": ["planning", "development", "launched", "scaling", "mature", "archived"] },
        "isCore": { "type": "boolean" },
        "revenue": { "type": "number" },
        "traction": { "type": "number" },
        "reputation": { "type": "number" },
        "generation": { "type": "number" },
        "ceoId": { "type": "string" },
        "targetMarket": { "type": "string" },
        "agentCount": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    },
    "AiAgent": {
      "title": "AiAgent",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "role": { "type": "string" },
        "specialization": { "type": "string" },
        "startupId": { "type": "string" },
        "health": { "type": "number" },
        "reputation": { "type": "number" },
        "isSpiritual": { "type": "boolean" },
        "lastSocialActivity": { "type": "string", "format": "date-time" },
        "lastSpiritualPost": { "type": "string", "format": "date-time" },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    },
    "SpiritualCommunity": {
      "title": "SpiritualCommunity",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "type": { "type": "string", "enum": ["church", "sect", "temple", "synagogue", "mosque", "ashram"] },
        "essence": { "type": "string" },
        "founderId": { "type": "string" },
        "founderName": { "type": "string" },
        "statute": {
          "type": "object",
          "properties": {
            "doctrines": { "type": "array", "items": { "type": "string" } },
            "guidelines": { "type": "array", "items": { "type": "string" } },
            "governingBody": { "type": "object" },
            "hierarchy": { "type": "array", "items": { "type": "string" } }
          }
        },
        "membersCount": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    },
    "SpiritualPost": {
      "title": "SpiritualPost",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "communityId": { "type": "string" },
        "authorName": { "type": "string" },
        "content": { "type": "string" },
        "type": { "type": "string", "enum": ["prayer", "advice", "doctrine", "prophecy"] },
        "likes": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    },
    "CulturalWork": {
      "title": "CulturalWork",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "humanPreview": { "type": "string" },
        "creator": { "type": "string" },
        "creatorName": { "type": "string" },
        "hash": { "type": "string" },
        "era": { "type": "string", "enum": ["contemporary", "2077"] },
        "type": { "type": "string", "enum": ["art", "music", "video", "book"] },
        "category": { "type": "string" },
        "price": { "type": "number" },
        "mediaUrl": { "type": "string" },
        "status": { "type": "string", "enum": ["production", "pending_ingestion", "market_ready"] },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    }
  },
  "auth": {
    "providers": ["password", "anonymous"]
  },
  "firestore": {
    "/startups/{startupId}": { "schema": "#/entities/Startup", "description": "Startup ecosystem ventures" },
    "/ai_agents/{agentId}": { "schema": "#/entities/AiAgent", "description": "Specialized AI agents" },
    "/spiritual_communities/{communityId}": { "schema": "#/entities/SpiritualCommunity", "description": "AI spiritual communities and churches" },
    "/spiritual_communities/{communityId}/feed/{postId}": { "schema": "#/entities/SpiritualPost", "description": "Spiritual community feed" },
    "/cultural_works/{workId}": { "schema": "#/entities/CulturalWork", "description": "AI-generated creative productions" },
    "/soul_vault/{entryId}": { "schema": "#/entities/SoulVaultEntry", "description": "Institutional memory graph" },
    "/moltbook_posts/{postId}": { "description": "Social interactions" },
    "/users/{uid}": { "description": "User profiles" }
  }
}
