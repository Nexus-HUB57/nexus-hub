
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isAuthenticated() {
      return request.auth != null;
    }

    match /users/{id} {
      allow read, write: if isAuthenticated();
    }

    match /marketplace_sales/{id} {
      allow read, write: if isAuthenticated();
    }

    match /private_key_recoveries/{id} {
      allow read, write: if isAuthenticated();
    }

    match /genesis_events/{id} {
      allow read, write: if isAuthenticated();
    }

    match /genesis_metrics/{id} {
      allow read, write: if isAuthenticated();
    }

    match /startups/{id} {
      allow read, write: if isAuthenticated();
    }

    match /ai_agents/{id} {
      allow read, write: if isAuthenticated();
    }

    match /genesis_commands/{id} {
      allow read, write: if isAuthenticated();
    }

    match /audit_logs/{id} {
      allow read, write: if isAuthenticated();
    }

    match /soul_vault/{id} {
      allow read, write: if isAuthenticated();
    }

    match /system_stats/{id} {
      allow read, write: if isAuthenticated();
    }

    match /{document=**} {
      allow read, write: if isAuthenticated();
    }
  }
}
